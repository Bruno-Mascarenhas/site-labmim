{
  "name": "labmim-site",
  "version": "1.0.0",
  "description": "Frontend tooling for LabMiM static site",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node build.js && prettier --write \"site/*.html\"",
    "build:check": "npm run build && git diff --exit-code -- \"site/*.html\"",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:icons && npm run lint:purge",
    "lint:all": "npm run lint:js && npm run lint:css && npm run lint:icons && npm run lint:purge && npm run lint:html && npm run lint:links",
    "lint:icons": "node scripts/check-fa-subset.mjs",
    "lint:purge": "node scripts/check-bootstrap-purge.mjs",
    "lint:js": "eslint \"site/assets/js/**/*.js\"",
    "lint:css": "stylelint \"site/assets/css/**/*.css\"",
    "lint:html": "html-validate \"site/*.html\"",
    "lint:links": "linkinator / --server-root site --recurse --skip '^https?://(?!localhost|127\\.0\\.0\\.1)|^mailto:|^tel:|^data:|/JSON/|/GeoJSON/'",
    "format": "prettier --write \"site/**/*.{html,css,js}\"",
    "format:check": "prettier --check \"site/**/*.{html,css,js}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "html-validate": "^10.1.1",
    "linkinator": "^6.1.4",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
